# DeepSeek API 配置（Chat 模型）
LLM_API_KEY=sk-your-deepseek-api-key
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# Embedding 配置
# 默认使用 HuggingFace 本地模型（无需 API Key）
# 如需 OpenAI 兼容 API，改为 EMAIL_PROVIDER=openai 并配置上面 LLM_API_KEY
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# RAG 检索参数
RAG_TOP_K=4
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=160
RAG_UPLOAD_DIR=data/uploaded_docs
